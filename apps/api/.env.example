DATABASE_URL="file:./dev.db"
JWT_SECRET="cambiami-con-una-stringa-random-lunga"
JWT_EXPIRES_IN="12h"
PORT=4000
# In sviluppo lascia "development". In produzione metti "production":
# in production il backend serve anche il frontend buildato (1 sola porta).
NODE_ENV="development"
# In dev il frontend gira su 5173 (Vite). In production il frontend
# è servito dallo stesso backend, quindi CORS_ORIGIN va impostato sullo stesso host:porta.
CORS_ORIGIN="http://localhost:5173"

# Credenziali admin iniziali (usate dal seed)
ADMIN_EMAIL="admin@udsagora.local"
ADMIN_PASSWORD="cambiami"
ADMIN_NAME="Amministratore"
