generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String        @id @default(cuid())
  username            String        @unique
  passwordHash        String
  fullName            String
  role                String        @default("SEGRETERIA")
  active              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  auditEvents         AuditLog[]
  cashClosings        CashClosing[]
  expenses            Expense[]
  approvedMemberships Membership[]  @relation("MembershipApprover")
}

model AcademicYear {
  id           String          @id @default(cuid())
  label        String          @unique
  startDate    DateTime
  endDate      DateTime
  active       Boolean         @default(false)
  createdAt    DateTime        @default(now())
  cashClosings CashClosing[]
  courses      Course[]
  memberships  Membership[]
  fees         MembershipFee[]
}

model MemberCategory {
  id        String          @id @default(cuid())
  code      String          @unique
  name      String
  notes     String?
  createdAt DateTime        @default(now())
  members   Member[]
  fees      MembershipFee[]
}

model MembershipFee {
  id             String         @id @default(cuid())
  academicYearId String
  categoryId     String
  type           String
  amountCents    Int
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  category       MemberCategory @relation(fields: [categoryId], references: [id])

  @@unique([academicYearId, categoryId, type])
}

model Member {
  id                String             @id @default(cuid())
  cognome           String
  nome              String
  codiceFiscale     String?            @unique
  dataNascita       DateTime?
  luogoNascita      String?
  gender            String?
  indirizzo         String?
  cap               String?
  citta             String?
  provincia         String?
  email             String?
  telefono          String?
  cellulare         String?
  categoryId        String
  privacyFirmataIl  DateTime?
  note              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  courseEnrollments CourseEnrollment[]
  category          MemberCategory     @relation(fields: [categoryId], references: [id])
  memberships       Membership[]

  @@index([cognome, nome])
}

model Membership {
  id              String       @id @default(cuid())
  memberId        String
  academicYearId  String
  type            String
  amountDueCents  Int
  amountPaidCents Int          @default(0)
  paymentDate     DateTime?
  paymentMethod   String?
  receiptNumber   String?
  status          String       @default("IN_ATTESA")
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  note            String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  approvedBy      User?        @relation("MembershipApprover", fields: [approvedById], references: [id])
  member          Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, academicYearId])
  @@index([status])
}

model Course {
  id             String             @id @default(cuid())
  academicYearId String
  codice         String?
  titolo         String
  descrizione    String?
  docente        String?
  costoCents     Int
  dataInizio     DateTime
  numeroSessioni Int
  postiMassimi   Int?
  sede           String?
  status         String             @default("IN_PREPARAZIONE")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  academicYear   AcademicYear       @relation(fields: [academicYearId], references: [id])
  enrollments    CourseEnrollment[]

  @@index([academicYearId, status])
}

model CourseEnrollment {
  id              String    @id @default(cuid())
  courseId        String
  memberId        String
  amountDueCents  Int
  amountPaidCents Int       @default(0)
  paymentDate     DateTime?
  paymentMethod   String?
  receiptNumber   String?
  status          String    @default("ATTIVA")
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  member          Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([courseId, memberId])
  @@index([memberId])
}

model Expense {
  id          String   @id @default(cuid())
  expenseDate DateTime
  description String   @db.VarChar(500)
  spenderName String
  amountCents Int
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expenseDate])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  payload    String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model CashClosing {
  id                          String                    @id @default(cuid())
  closureDate                 DateTime                  @db.Date
  academicYearId              String
  expectedCashFromMemberships Int                       @default(0)
  expectedCashFromCourses     Int                       @default(0)
  expectedCashFromOther       Int                       @default(0)
  expensesTotal               Int                       @default(0)
  previousPettyCash           Int                       @default(0)
  countedCashTotal            Int                       @default(0)
  pettyCashRemaining          Int                       @default(0)
  bankDepositAmount           Int                       @default(0)
  bankDepositNumber           String?                   @db.VarChar(100)
  bankDepositDate             DateTime?                 @db.Date
  difference                  Int                       @default(0)
  notes                       String?
  userId                      String
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  academicYear                AcademicYear              @relation(fields: [academicYearId], references: [id])
  user                        User                      @relation(fields: [userId], references: [id])
  denominationCounts          CashClosingDenomination[]

  @@unique([closureDate, academicYearId])
  @@index([userId])
  @@index([closureDate])
}

model CashClosingDenomination {
  id                String      @id @default(cuid())
  cashClosingId     String
  denominationCents Int
  quantity          Int         @default(0)
  subtotal          Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  cashClosing       CashClosing @relation(fields: [cashClosingId], references: [id], onDelete: Cascade)

  @@unique([cashClosingId, denominationCents])
  @@index([cashClosingId])
}
